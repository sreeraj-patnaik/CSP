# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-secret-key-change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development

# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/csp_db?sslmode=require

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── Media / Storage ───────────────────────────────────────────────────────────
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=ap-south-1

# ── AI / Ollama ───────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:latest
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
CHROMA_PERSIST_DIR=./data/chroma

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your@email.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=CSP Project <your@email.com>

# ── Project Meta ──────────────────────────────────────────────────────────────
PROJECT_NAME=Community Service Project
PROJECT_TOPIC=Safe Usage of Internet and Cybercrime Awareness in Rural Areas
MENTOR_NAME=Dr. R. Rajender
COLLEGE_NAME=Lendi Institute of Engineering and Technology
